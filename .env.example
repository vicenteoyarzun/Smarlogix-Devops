# Database Configuration
DB_USER=smartlogix
DB_PASSWORD=smartlogix123
DB_NAME=smartlogix_db
DB_HOST=postgres
DB_PORT=5432

# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/smartlogix-github-role

# ECR Configuration
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com

# ECS Configuration
ECS_CLUSTER_NAME=smartlogix-cluster
ECS_TASK_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/ecsTaskExecutionRole
ECS_TASK_ROLE_ARN=arn:aws:iam::123456789012:role/ecsTaskRole

# Service Configuration
EUREKA_SERVER_URL=http://eureka-server:8761/eureka
FRONTEND_PORT=80
BACKEND_PORT=8080

# Spring Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SMARTLOGIX=DEBUG

# GitHub Actions
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
